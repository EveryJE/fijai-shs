generator client {
  provider = "prisma-client-js"
  output   = "../../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model DigitalCard {
  id      String @id @default(uuid())
  eventId String

  cardCode          String  @unique // unique code for this digital card
  holderName        String
  email             String?
  profilePictureUrl String?
  classYear         String? // e.g. "Class of 2015"
  qrCodeUrl         String?
  isActive          Boolean @default(true)

  issuedAt DateTime @default(now())

  event     Event      @relation(fields: [eventId], references: [id])
  donations Donation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([eventId])
  @@index([isActive])
  @@map("digital_cards")
}

model Donation {
  id        String @id @default(uuid())
  reference String @unique

  eventId         String // every donation belongs to an event
  contactPersonId String? // nullable — if through Contact Person
  digitalCardId   String? // nullable — if through Digital Card
  donationItemId  String? // nullable — can be general donation

  donorName  String?
  donorEmail String
  phone      String?

  amount   Decimal @db.Decimal(12, 2)
  currency String  @default("GHS")

  status        String @default("pending") // pending | paid | failed
  paymentMethod String @default("paystack") // paystack | manual

  userId String? // Supabase auth user id (null for anonymous donors)

  providerReference String? // Paystack transaction id
  providerResponse  Json? // Full Paystack webhook payload
  metadata          Json? // Additional data

  // Moment — optional memory/photo the donor can attach
  momentFileUrl String? // uploaded file URL (image, etc.)
  momentCaption String? // description of the moment / memory

  verifiedAt DateTime?
  paidAt     DateTime?
  donatedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  event         Event          @relation(fields: [eventId], references: [id])
  contactPerson ContactPerson? @relation(fields: [contactPersonId], references: [id])
  digitalCard   DigitalCard?   @relation(fields: [digitalCardId], references: [id])
  donationItem  DonationItem?  @relation(fields: [donationItemId], references: [id])

  @@index([eventId])
  @@index([status])
  @@index([contactPersonId])
  @@index([digitalCardId])
  @@index([donationItemId])
  @@index([userId])
  @@map("donations")
}

model Organization {
  id             String  @id @default(uuid())
  name           String
  primaryColor   String  @default("#8B0000") // hex
  secondaryColor String  @default("#DAA520") // hex
  tertiaryColor  String  @default("#1B3A5C") // hex
  logoUrl        String?

  events Event[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("organizations")
}

model Event {
  id             String @id @default(uuid())
  organizationId String

  title       String
  description String?
  status      String    @default("draft") // draft | active | closed
  startDate   DateTime?
  endDate     DateTime?

  organization   Organization    @relation(fields: [organizationId], references: [id])
  categories     Category[]
  contactPersons ContactPerson[]
  digitalCards   DigitalCard[]
  donations      Donation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([status])
  @@map("events")
}

model Category {
  id      String @id @default(uuid())
  eventId String

  name         String
  color        String // hex — dynamic per category
  displayOrder Int    @default(0)

  event         Event          @relation(fields: [eventId], references: [id])
  donationItems DonationItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([eventId])
  @@map("categories")
}

model DonationItem {
  id         String @id @default(uuid())
  categoryId String

  name         String
  icon         String? // emoji / SVG code / icon-name
  color        String? // hex — dynamic per item
  targetAmount Decimal? @db.Decimal(12, 2)
  displayOrder Int      @default(0)

  category  Category   @relation(fields: [categoryId], references: [id])
  donations Donation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([categoryId])
  @@map("donation_items")
}

model ContactPerson {
  id      String @id @default(uuid())
  eventId String

  uniqueCode        String  @unique // auto-generated
  name              String
  profilePictureUrl String?
  classYear         String? // e.g. "Class of 2015"
  email             String?
  phone             String?
  metadata          Json? // extra details
  qrCodeUrl         String? // generated QR link/image

  event     Event      @relation(fields: [eventId], references: [id])
  donations Donation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([eventId])
  @@map("contact_persons")
}

model Profile {
  id        String  @id @default(uuid())
  email     String  @unique
  fullName  String?
  avatarUrl String?
  phone     String? @unique
  role      String  @default("admin") // admin | rsvp | cardholder

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("profiles")
}
